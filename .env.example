# Copy to .env and fill in only what your chosen setup uses.

# Common app secrets
LINTIC_ADMIN_KEY=replace-with-admin-key
LINTIC_SECRET_KEY=replace-with-signing-secret

# Model provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Optional model endpoint override for openai-compatible or local-openai
LINTIC_BASE_URL=

# Database
DATABASE_URL=
LINTIC_DATABASE_PATH=./lintic.db

# Runtime
PORT=3300
