{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "@lintic/core": ["./packages/core/src/index.ts"],
      "@lintic/adapters": ["./packages/adapters/src/index.ts"],
      "@lintic/cli": ["./packages/cli/src/index.ts"],
      "@lintic/frontend": ["./packages/frontend/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts"]
}
