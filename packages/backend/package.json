{
  "name": "@lintic/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p ../core/tsconfig.json && tsc -p ../adapters/tsconfig.json && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p ../core/tsconfig.json && tsc -p ../adapters/tsconfig.json && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lintic/adapters": "*",
    "@lintic/core": "*",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0"
  }
}
